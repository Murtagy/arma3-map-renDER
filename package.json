{
  "name": "arma3-map-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx watch server/index.ts",
    "client": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "build:native": "cd native && npx node-gyp rebuild",
    "setup": "npm install && npm run build:native && npm run build",
    "screenshot": "tsx scripts/screenshot.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "lzo": "^0.4.11",
    "lzo-decompress": "^1.0.11",
    "sharp": "^0.34.5",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.5",
    "@types/three": "^0.170.0",
    "concurrently": "^9.0.0",
    "puppeteer": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
